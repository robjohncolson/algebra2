  "vocabulary": [
    {
      "term": "asymptote",
      "definition": "A line that a graph approaches but never reaches."
    },
    {
      "term": "constant of variation",
      "definition": "The constant k in an inverse variation; the product xy = k."
    },
    {
      "term": "inverse variation",
      "definition": "A relationship where one variable increases as the other decreases proportionally; xy = k."
    },
    {
      "term": "reciprocal function",
      "definition": "A function that maps each non-zero input to its reciprocal, y = 1/x."
    }
